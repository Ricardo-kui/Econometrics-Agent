# for openai LLM api, can be multiple keys, split by comma(,)
OPENAI_API_KEYS="sk-xxxxx"
OPENAI_API_BASE_URLS="https://api.openai.com/v1"

# for azure openai api
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_ENDPOINT=

# for ollama
OLLAMA_BASE_URL='http://localhost:11434'

# for tongyi qwen
DASHSCOPE_API_KEY=""

DEEPSEEK_API_KEY=""
MOONSHOT_API_KEY=""

# for google search
SERPER_API_KEY=""

# for python code execution
E2B_API_KEY=""

# for web ui
DATA_DIR="./db"
AGENTICA_HOME="./db"

# DO NOT TRACK
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true

DEFAULT_MODELS="gpt-3.5-turbo"
MODEL_FILTER_ENABLED=true
# set available models
MODEL_FILTER_LIST="gpt-3.5-turbo,gpt-3.5-turbo-16k,gpt-4,gpt-4-1106-preview"

# enable/disable tools
ENABLE_RUN_PYTHON_CODE_TOOL=true
ENABLE_SEARCH_TOOL=true
ENABLE_URL_CRAWLER_TOOL=true

ENV="dev"
DEFAULT_USER_ROLE="admin"

# requests per day, -1 means no limit
RPD=-1
# requests per minute, -1 means no limit
RPM=-1

# rag settings
RAG_EMBEDDING_MODEL="shibing624/text2vec-base-multilingual"
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
RAG_TOP_K=5
# Maximum length of document text. -1 means no limit.
DOC_TEXT_LENGTH_LIMIT=-1

# =====================================
# 邮箱验证配置 (Email Verification)
# =====================================

# 是否启用邮箱验证
EMAIL_VERIFICATION_ENABLED=true

# SMTP 服务器配置
SMTP_SERVER=""              # 例如: smtp.gmail.com, smtp.qq.com, smtp.163.com
SMTP_PORT=587               # 通常 Gmail=587, QQ/163=587 或 25
SMTP_USERNAME=""            # 你的邮箱地址
SMTP_PASSWORD=""            # 邮箱密码或应用专用密码
SMTP_USE_TLS=true          # 是否使用 TLS 安全连接

# 发件人信息
SMTP_FROM_EMAIL=""          # 发件人邮箱 (通常与 SMTP_USERNAME 相同)
SMTP_FROM_NAME="Econometrics Agent"  # 发件人显示名称

# 验证设置
EMAIL_VERIFICATION_TOKEN_EXPIRES_HOURS=24  # 验证链接过期时间 (小时)

# 前端访问地址 (用于邮件中的验证链接)
FRONTEND_URL="http://localhost:5173"

# =====================================
# 主要邮件提供商配置示例:
# =====================================
# 
# Gmail:
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password  # 需要生成应用专用密码
#
# QQ邮箱:
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@qq.com
# SMTP_PASSWORD=your_authorization_code  # 需要开启 SMTP 服务
#
# 163邮箱:
# SMTP_SERVER=smtp.163.com
# SMTP_PORT=587 
# SMTP_USERNAME=your_email@163.com
# SMTP_PASSWORD=your_client_password  # 需要开启客户端授权密码
# =====================================

# web ui settings
WEBUI_BASE_URL="http://localhost:8080"

